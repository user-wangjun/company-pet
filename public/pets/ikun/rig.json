    "back": {
      "shape": "Use back-derived crossed shoulder straps from the reference model.",
      "rule": "Back-view actions must show back straps and back hair shape, not front face or front overalls highlights."
    },
    "motion": "Straps follow spine and shoulder joints, but remain attached to the overalls body."
  },
  "constraints": [
    {
      "id": "series-continuity",
      "rule": "Rows in the same action series should be played by sequenceIndex unless a future runtime explicitly branches."
    },
    {
      "id": "back-view-only",
      "rule": "Any action marked back must use the back view layers, not a rotated front model."
    },
    {
      "id": "basketball-source-truth",
      "rule": "No-ball source segments stay no-ball. Mixed segments must list visible and absent frames."
    },
    {
      "id": "whole-ball",
      "rule": "Basketball is one prop layer. It may rotate, translate, scale, hide, or leave the frame, but it may not break apart."
    }
  ]
