  "propRules": {
    "basketball": {
      "isWholeProp": true,
      "fragmentationAllowed": false,
      "canBeHidden": true,
      "canBeAttachedToHand": true,
      "canPassUnderLeg": true,
      "canBeThrown": true,
      "states": [
        "hidden",
        "held-left",
        "held-left-low",
        "held-right",
        "held-right-side",
        "dribble-low",
        "dribble-high",
        "controlled-high",
