    }
  },
  "strapRules": {
    "front": {
      "leftStrap": "Anchor from left shoulder to overalls waist. It can stretch slightly during shoulder and spine rotation.",
      "rightStrap": "Anchor from right shoulder to overalls waist. It can stretch slightly during shoulder and spine rotation."
