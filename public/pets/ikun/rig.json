        "center-entry",
        "under-leg-center",
        "emerge-image-left",
        "controlled-image-left-low",
        "center-return",
        "held-image-right"
      ],
      "visibilityRule": "Use actions.json and action-board.json. Do not draw a basketball in source ranges marked none.",
      "rotationRule": "When the ball moves, rotate the complete basketball layer as one object and record frame angles for planned actions.",
